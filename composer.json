{
    "name": "christianjbrown/met-office-api",
    "require": {
        "php": "^8.2",
        "christianjbrown/user-friendly-exception": "dev-main",
        "christianjbrown/json-api-client": "dev-main",
        "psr/http-client": "^1.0"
    },
    "scripts": {
        "test": [
            "./vendor/bin/phpunit && open ./.code-coverage/index.html"
        ]
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\MetOffice\\": "src/",
            "ChristianBrown\\MetOffice\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/user-friendly-exception.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/json-api-client.git"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10.3",
        "ext-xdebug": "*"
    }
}
