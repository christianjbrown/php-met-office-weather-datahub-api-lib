{
    "name": "christianjbrown/php-met-office-api-lib",
    "require": {
        "php": "^8.2",
        "christianjbrown/php-user-friendly-exception-lib": "^1.0",
        "christianjbrown/php-json-api-client-lib": "^1.0",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "ext-xdebug": "*",
        "christianjbrown/php-code-quality-scripts": "dev-main",
        "phpunit/phpunit": "^11.0@dev"
    },
    "config": {
        "bin-dir": "bin"
    },
    "scripts": {
        "test": [
            "clear && XDEBUG_MODE=coverage ./bin/phpunit && open ./.phpunit.cache/code-coverage-html/index.html"
        ],
        "check-style": [
            "clear && ./bin/php-cs ./src ./tests"
        ],
        "check-style-diff": [
            "clear && ./bin/php-cs-diff"
        ],
        "fix-style": [
            "clear && ./bin/php-cs-fix ./src ./tests"
        ],
        "fix-style-diff": [
            "clear && ./bin/php-cs-fix-diff"
        ]
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\MetOffice\\DataPoint\\": "src/",
            "ChristianBrown\\MetOffice\\DataPoint\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-code-quality-scripts.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-user-friendly-exception-lib.git"
        },
        {
            "type": "github",
            "url": "git@github.com:christianjbrown/php-json-api-client-lib.git"
        }
    ]
}
